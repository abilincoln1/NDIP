# Database
DATABASE_URL=postgresql://agora_user:agora_pass@db:5432/agora_db

# JWT
SECRET_KEY=change-me-to-a-random-32-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Redis (optional)
REDIS_URL=redis://redis:6379/0

# ── Social API Keys ────────────────────────────────────────────────────────────
# YouTube Data API v3
# Get at: https://console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_API_KEY=

# X (Twitter) API v2 — requires Basic paid tier ($100/mo)
# Get at: https://developer.twitter.com
TWITTER_BEARER_TOKEN=

# Reddit — free, create "script" app at reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=AgoraObservatory/1.0

# NewsAPI — free tier 100 req/day
# Get at: https://newsapi.org
NEWS_API_KEY=

# Meta Graph API — for Facebook Pages / Instagram you own/manage
# Get at: https://developers.facebook.com
META_ACCESS_TOKEN=
META_PAGE_IDS=   # comma-separated page IDs e.g. 123456789,987654321

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
